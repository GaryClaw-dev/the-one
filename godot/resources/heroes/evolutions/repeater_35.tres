[gd_resource type="Resource" script_class="EvolutionPointData" load_steps=4 format=3]

[ext_resource type="Script" path="res://scripts/heroes/evolution_point_data.gd" id="1"]
[ext_resource type="Script" path="res://scripts/heroes/evolution_option_data.gd" id="2"]

[sub_resource type="Resource" id="gunslinger"]
script = ExtResource("2")
key = "gunslinger"
display_name = "Gunslinger"
description = "Lead Rain — dual-fire bullet hell fills the screen"
color = Color(1, 0.843, 0, 1)
tier = 4
stat_bonuses = [{"stat": 4, "type": 1, "value": 0.45, "label": "+45% ATK Speed"}, {"stat": 8, "type": 0, "value": 1.0, "label": "+1 Projectile"}, {"stat": 3, "type": 1, "value": -0.3, "label": "-30% ATK Damage"}, {"stat": 0, "type": 1, "value": 0.2, "label": "+20% Max HP"}]
passives = ["Bullet Time: 50% chance to attack twice", "Spray and Pray: 20% chance to split on hit", "Hot Streak: Every 10th hit = guaranteed crit"]

[sub_resource type="Resource" id="siege_master"]
script = ExtResource("2")
key = "siege_master"
display_name = "Siege Master"
description = "Walking Artillery — explosive bolts leave fire zones"
color = Color(1, 0.271, 0, 1)
tier = 4
stat_bonuses = [{"stat": 4, "type": 1, "value": -0.4, "label": "-40% ATK Speed"}, {"stat": 3, "type": 1, "value": 0.8, "label": "+80% ATK Damage"}, {"stat": 10, "type": 0, "value": 60.0, "label": "+60 AoE Radius"}, {"stat": 9, "type": 0, "value": 1.0, "label": "+1 Pierce"}, {"stat": 0, "type": 1, "value": 0.25, "label": "+25% Max HP"}]
passives = ["Payload: All shots explode on impact", "Scorched Earth: Explosions leave 3s fire zones", "Concussive Force: Explosions push + 40% slow"]

[resource]
script = ExtResource("1")
