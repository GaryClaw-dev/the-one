; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="The One"
config/description="Progression RPG with class branching. Start as The Noob, evolve into powerful classes."
run/main_scene="res://scenes/game.tscn"
config/features=PackedStringArray("4.6")

[autoload]

GameEvents="*res://scripts/core/game_events.gd"
GameManager="*res://scripts/core/game_manager.gd"
ItemDatabase="*res://scripts/loot/item_database.gd"
AudioManager="*res://scripts/core/audio_manager.gd"
ClassSelectionUI="*res://scenes/ui/class_selection_ui.tscn"

[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[dotnet]

project/assembly_name="The One"

[input]

pause={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":0,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":4194305,"physical_keycode":0,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}

[layer_names]

2d_physics/layer_1="Hero"
2d_physics/layer_2="Enemy"
2d_physics/layer_3="HeroProjectile"
2d_physics/layer_4="EnemyProjectile"
2d_physics/layer_5="Pickup"
3d_physics/layer_1="Hero"
3d_physics/layer_2="Enemy"
3d_physics/layer_3="HeroProjectile"
3d_physics/layer_4="EnemyProjectile"
3d_physics/layer_5="Pickup"

[rendering]

textures/canvas_textures/default_texture_filter=0
environment/defaults/default_clear_color=Color(0.12, 0.11, 0.15, 1)
