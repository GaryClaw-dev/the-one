[sub_resource type="GDScript" id="GDScript_boot"]
script/source = "extends Node

func _ready() -> void:
	var hero_scene = preload('res://scenes/hero_archer.tscn')
	await get_tree().create_timer(0.2).timeout
	GameManager.start_game(hero_scene)
"

[sub_resource type="GDScript" id="GDScript_camera"]
script/source = "extends Camera2D

func _process(_delta: float) -> void:
	var hero = get_tree().get_first_node_in_group('hero')
	if hero:
		global_position = hero.global_position
"

