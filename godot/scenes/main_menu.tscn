[gd_scene load_steps=2 format=3 uid="uid://c8mainmenu01"]

[sub_resource type="GDScript" id="GDScript_menu"]
script/source = "extends Control

func _ready() -> void:
	$VBox/PlayBtn.pressed.connect(_on_play)
	$VBox/QuitBtn.pressed.connect(_on_quit)

func _process(_delta: float) -> void:
	var t := sin(Time.get_ticks_msec() * 0.002) * 0.5 + 0.5
	$VBox/Title.scale = Vector2.ONE * lerpf(0.95, 1.05, t)

func _on_play() -> void:
	get_tree().change_scene_to_file('res://scenes/game.tscn')

func _on_quit() -> void:
	get_tree().quit()
"

[node name="MainMenu" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = SubResource("GDScript_menu")

