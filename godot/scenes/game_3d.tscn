[sub_resource type="GDScript" id="GDScript_camera"]
script/source = "extends Camera3D

func _process(_delta: float) -> void:
	var hero = get_tree().get_first_node_in_group('hero')
	if hero and hero is Node3D:
		var h = hero as Node3D
		global_position = Vector3(h.global_position.x, 25, h.global_position.z + 10)
"

